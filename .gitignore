# Large single-cell data files (exceed GitHub's 100MB/file limit) — keep on disk, not in git
*.h5ad
*.h5
*.rds
*.loom
*.zarr/

# Local data staging + generated outputs
data/
outputs/

# Generated figures / tables / logs
*.png
*.pdf
*.csv
slurm-*.out
*.log

# Python bytecode / caches
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# OS / editor cruft
.DS_Store
*.swp

# --- but DO track small marker references we ship on purpose ---
!Resources/*.rds
